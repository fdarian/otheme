{
  "name": "otheme",
  "version": "0.1.0",
  "description": "Apply shared themes across editor and terminal targets",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fdarian/otheme.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/fdarian/otheme",
  "bin": {
    "otheme": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.83",
    "@otheme/core": "workspace:*",
    "effect": "4.0.0-beta.83"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "^1.2.17"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target=node --outfile dist/cli.js",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "check": "bun run check:type && bun run check:lint",
    "check:lint": "biome check .",
    "check:type": "tsc --noEmit",
    "prepack": "bun run build"
  }
}
