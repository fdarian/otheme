{
  "name": "otheme-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "check": "turbo run check",
    "ci:release": "changeset publish",
    "ci:version": "changeset version",
    "docs:build": "bun --cwd apps/docs run build",
    "docs:dev": "bun --cwd apps/docs run dev",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.5.8"
  }
}
